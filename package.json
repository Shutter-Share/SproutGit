{
  "name": "sprout-git",
  "version": "0.1.0",
  "description": "SproutGit: a fast, worktree-first cross-platform Git desktop app",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:security": "cd src-tauri && cargo test --all-targets",
    "tauri": "tauri",
    "test:tauri:prepare": "pnpm run build && cd src-tauri && cargo build",
    "test:tauri:driver": "node tests/tauri-driver/smoke.mjs",
    "test:tauri": "npm run test:tauri:prepare && npm run test:tauri:driver"
  },
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "cookie": "0.7.2",
      "dompurify": "3.4.0"
    }
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@monaco-editor/loader": "^1.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "lucide-svelte": "^1.0.1",
    "monaco-editor": "^0.55.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "oxlint": "^1.61.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.9",
    "webdriverio": "^9.27.0"
  }
}
