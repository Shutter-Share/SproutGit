{
  "name": "sproutgit",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:screenshots": "cross-env CAPTURE_SCREENSHOTS=1 PLAYWRIGHT_SCREENSHOT_TARGET=./website/src/assets/screenshots playwright test -c e2e/playwright.config.ts --grep @screenshots",
    "screenshots": "pnpm --filter @sproutgit/e2e screenshots",
    "lint": "oxlint --config .oxlintrc.json app/src packages/ui/src packages/git/src packages/terminal/src packages/types/src",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\" --ignore-path .gitignore",
    "postinstall": "node scripts/patch-electron-plist.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "oxlint": "^1.65.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/InterestingSoftware/SproutGit.git"
  },
  "homepage": "https://github.com/InterestingSoftware/SproutGit#readme",
  "bugs": {
    "url": "https://github.com/InterestingSoftware/SproutGit/issues"
  }
}
