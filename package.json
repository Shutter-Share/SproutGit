{
  "name": "sprout-git",
  "version": "0.1.0",
  "description": "SproutGit: a fast, worktree-first cross-platform Git desktop app",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:security": "cd src-tauri && cargo test --all-targets",
    "tauri": "tauri",
    "test:tauri:prepare": "pnpm run build && cd src-tauri && cargo build",
    "test:tauri:driver": "node tests/tauri-driver/smoke.mjs",
    "test:tauri": "npm run test:tauri:prepare && npm run test:tauri:driver"
  },
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "cookie": "0.7.2"
    }
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "highlight.js": "^11.11.1",
    "lucide-svelte": "^1.0.1",
    "monaco-editor": "^0.55.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "oxlint": "^0.3.0",
    "prettier": "^3.2.5",
    "prettier-plugin-svelte": "^3.2.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "webdriverio": "^9.27.0"
  }
}
