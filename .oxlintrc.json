{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "globals": {
    "window": "readonly"
  },
  "rules": {
    "no-console": "warn",
    "no-debugger": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-unused-vars": "off",
    "prefer-const": "warn",
    "react/react-in-jsx-scope": "off",
    "react/rules-of-hooks": "error",
    "react/jsx-key": "error"
  },
  "plugins": ["react"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "ignorePatterns": [
    "node_modules",
    "**/out/**",
    "**/dist-electron/**",
    "**/*.d.ts",
    "old/**"
  ]
}
