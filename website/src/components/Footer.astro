---
const GITHUB = 'https://github.com/InterestingSoftware/SproutGit';
const year = new Date().getFullYear();
---

<!-- CTA Band -->
<section class="relative overflow-hidden border-t" style="border-color: var(--sg-border-subtle); background: var(--sg-surface);">
  <div class="blob blob-a absolute top-[-40%] right-[-10%] w-[50%] h-[200%] rounded-full"
       style="background: color-mix(in srgb, var(--sg-primary) 10%, transparent); filter: blur(100px);"></div>
  <div class="blob blob-b absolute bottom-[-40%] left-[-10%] w-[40%] h-[160%] rounded-full"
       style="background: color-mix(in srgb, var(--sg-accent) 7%, transparent); filter: blur(80px); animation-delay:-5s;"></div>

  <div class="relative z-10 max-w-2xl mx-auto px-12 py-28 text-center" data-animate>
    <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:var(--sg-primary); letter-spacing:0.1em;">
      Open source · Early preview
    </p>
    <h2 class="font-bold tracking-tighter mb-5" style="font-size: clamp(2rem, 5vw, 3.4rem); letter-spacing: -0.04em; color: var(--sg-text); line-height: 1.08;">
      Try it. Break it.<br>
      <span style="color: var(--sg-primary);">Help us ship it.</span>
    </h2>
    <p class="text-lg leading-relaxed mb-10 mx-auto max-w-lg" style="color: var(--sg-text-dim);">
      SproutGit is an early prototype under active development.
      The best way to support it is to star the repo, open issues,
      and contribute.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href={GITHUB} target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-2.5 px-8 py-4 rounded-xl text-base font-bold text-white transition-all hover:-translate-y-0.5"
         style="background: var(--sg-primary);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        Star on GitHub
      </a>
      <a href={`${GITHUB}/issues`} target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-2 px-8 py-4 rounded-xl text-base font-bold transition-all"
         style="color: var(--sg-primary); border: 1.5px solid color-mix(in srgb, var(--sg-primary) 30%, transparent);">
        Open an issue ↗
      </a>
    </div>
  </div>
</section>

<!-- Footer — from Stitch baseline -->
<footer style="background: var(--sg-surface); border-top: 1px solid var(--sg-border-subtle);">
  <div class="flex flex-col md:flex-row justify-between items-center px-12 py-14 w-full max-w-screen-2xl mx-auto gap-8">
    <div class="flex flex-col gap-3">
      <a href="/" class="flex items-center gap-2 text-base font-bold no-underline" style="color: var(--sg-text); letter-spacing: -0.02em;">
        <img src="/logo.svg" alt="SproutGit logo" width="20" height="20" class="w-5 h-5"/>
        SproutGit
      </a>
      <p class="text-xs uppercase tracking-widest" style="color: var(--sg-text-faint);">
        © {year} Interesting Software · MIT License
      </p>
    </div>

    <div class="flex flex-wrap gap-8 justify-center">
      {[
        { label: 'GitHub',       href: GITHUB },
        { label: 'Issues',       href: `${GITHUB}/issues` },
        { label: 'Releases',     href: `${GITHUB}/releases` },
        { label: 'Contributing', href: `${GITHUB}/blob/main/CONTRIBUTING.md` },
      ].map(link => (
        <a href={link.href} target="_blank" rel="noopener noreferrer"
           class="text-xs uppercase tracking-widest transition-colors hover:text-[var(--sg-primary)]"
           style="color: var(--sg-text-faint);">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
