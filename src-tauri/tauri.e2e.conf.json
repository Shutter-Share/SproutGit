{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "SproutGit",
        "width": 1024,
        "height": 768,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 21
        }
      }
    ],
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "e2e-playwright",
          "description": "Additional permissions for E2E-only Playwright runs",
          "windows": [
            "main"
          ],
          "permissions": [
            "playwright:default"
          ]
        }
      ]
    }
  }
}