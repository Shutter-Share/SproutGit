#!/usr/bin/env sh

# Ensure cargo is available (required for Rust checks and tests).
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

set -e

echo "--- [pre-commit] 1/7 Rust target cleanup"
pnpm run cleanup:rust-targets:delete

echo "--- [pre-commit] 2/7 Rust unit tests"
(cd src-tauri && cargo test --lib)

echo "--- [pre-commit] 3/7 pnpm tests"
pnpm run test

echo "--- [pre-commit] 4/7 docs drift lint"
pnpm run lint:docs

echo "--- [pre-commit] 5/7 oxlint"
pnpm run lint

echo "--- [pre-commit] 6/7 TypeScript/Svelte check"
pnpm run check

echo "--- [pre-commit] 7/8 Playwright E2E build"
pnpm run test:e2e:build

echo "--- [pre-commit] 8/8 Playwright E2E tests"
SPROUTGIT_E2E_SKIP_BUILD=1 pnpm run test:e2e
